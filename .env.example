# Credenciais SMTP do SendPulse — configure estas variáveis no EasyPanel.
# (Este arquivo é só um modelo; não coloque segredos reais aqui.)

# SMTP do SendPulse (Configurações → SMTP no painel do SendPulse)
SMTP_HOST=smtp-pulse.com
SMTP_PORT=587
SMTP_USER=seu-login-smtp@exemplo.com
SMTP_PASS=sua-senha-smtp
SMTP_AUTH=true
SMTP_STARTTLS=true
SMTP_SSL=false

# Para onde os contatos são enviados e o remetente exibido.
# MAIL_FROM precisa ser um remetente verificado no SendPulse.
MAIL_TO=contato@diverscinnova.com
MAIL_FROM=contato@diverscinnova.com

# Porta HTTP (opcional; padrão 8080)
# PORT=8080
